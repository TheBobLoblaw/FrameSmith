<Window x:Class="PoleBarnGenerator.UI.PoleBarnDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PoleBarnGenerator.UI"
        Title="Pole Barn Generator"
        Width="780" Height="720"
        MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="8,8">
            <Button Content="Load Preset..." Width="100" Margin="4" Click="OnLoadPreset"/>
            <Button Content="Generate" Width="100" Margin="4" IsDefault="True"
                    Click="OnGenerate" FontWeight="Bold"
                    Background="#2E7D32" Foreground="White"/>
            <Button Content="Cancel" Width="80" Margin="4" IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="StatusText" Text="Enter building dimensions and click Generate."/>
        </StatusBar>

        <!-- Tabbed Content -->
        <TabControl Margin="4" x:Name="tabMain">

            <!-- ═══ Tab 1: Dimensions ═══ -->
            <TabItem Header="📐 Dimensions">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <GroupBox Header="Primary Dimensions">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Building Width:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtWidth" Text="30"/>
                                <Label Grid.Row="0" Grid.Column="2" Content="ft" FontWeight="Normal"/>

                                <Label Grid.Row="0" Grid.Column="3" Content="Building Length:"/>
                                <TextBox Grid.Row="0" Grid.Column="4" x:Name="txtLength" Text="40"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Eave Height:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEaveHeight" Text="12"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="ft"/>

                                <Label Grid.Row="1" Grid.Column="3" Content="Roof Pitch:"/>
                                <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
                                    <TextBox x:Name="txtPitch" Text="4" Width="40"/>
                                    <Label Content="/12" FontWeight="Normal"/>
                                </StackPanel>

                                <Label Grid.Row="2" Grid.Column="0" Content="Bay Spacing:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtBaySpacing" Text="10"/>
                                <Label Grid.Row="2" Grid.Column="2" Content="ft"/>

                                <Label Grid.Row="2" Grid.Column="3" Content="Computed Bays:"/>
                                <Label Grid.Row="2" Grid.Column="4" x:Name="lblBayCount" Content="4" FontWeight="Bold"/>
                            </Grid>
                        </GroupBox>

                        <!-- Computed Summary -->
                        <GroupBox Header="Computed Summary">
                            <StackPanel x:Name="pnlSummary">
                                <TextBlock x:Name="txtSummary" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                           Text="Click 'Generate' to compute..."/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 2: Structure ═══ -->
            <TabItem Header="🏗 Structure">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <GroupBox Header="Structural Options">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Post Size:"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbPostSize" SelectedIndex="1">
                                    <ComboBoxItem Content="4x4"/>
                                    <ComboBoxItem Content="6x6"/>
                                    <ComboBoxItem Content="8x8"/>
                                </ComboBox>

                                <Label Grid.Row="0" Grid.Column="2" Content="Truss Type:"/>
                                <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cmbTrussType" SelectedIndex="0" Width="160"
                                          SelectionChanged="OnTrussTypeChanged">
                                    <ComboBoxItem Content="Common Gable"/>
                                    <ComboBoxItem Content="Scissor (Vaulted)"/>
                                    <ComboBoxItem Content="Mono-Slope (Shed)"/>
                                    <ComboBoxItem Content="Gambrel (Barn)"/>
                                    <ComboBoxItem Content="Monitor (Raised Center)"/>
                                    <ComboBoxItem Content="Attic Storage"/>
                                </ComboBox>

                                <Label Grid.Row="1" Grid.Column="0" Content="Girt Spacing:"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="txtGirtSpacing" Text="24" Width="50"/>
                                    <Label Content="in" FontWeight="Normal"/>
                                </StackPanel>

                                <Label Grid.Row="1" Grid.Column="2" Content="Purlin Spacing:"/>
                                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                                    <TextBox x:Name="txtPurlinSpacing" Text="24" Width="50"/>
                                    <Label Content="in" FontWeight="Normal"/>
                                </StackPanel>

                                <Label Grid.Row="2" Grid.Column="0" Content="Eave Overhang:"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="txtOverhangEave" Text="1" Width="50"/>
                                    <Label Content="ft" FontWeight="Normal"/>
                                </StackPanel>

                                <Label Grid.Row="2" Grid.Column="2" Content="Gable Overhang:"/>
                                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal">
                                    <TextBox x:Name="txtOverhangGable" Text="1" Width="50"/>
                                    <Label Content="ft" FontWeight="Normal"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Truss type description -->
                        <GroupBox Header="Roof Type Description">
                            <TextBlock x:Name="txtTrussDescription" TextWrapping="Wrap"
                                       FontStyle="Italic" Margin="4"
                                       Text="Standard symmetrical gable roof with peak at center. The most common pole barn roof type."/>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 3: Openings (NEW) ═══ -->
            <TabItem Header="🚪 Openings">
                <local:OpeningManagerControl x:Name="openingManager"/>
            </TabItem>


            <!-- ═══ Tab 4: Lean-Tos (Sprint 2) ═══ -->
            <TabItem Header="🏠 Lean-Tos">
                <local:LeanToControl x:Name="leanToManager"/>
            </TabItem>

            <!-- ═══ Tab 5: Exterior (Sprint 4) ═══ -->
            <TabItem Header="🏡 Exterior">
                <local:ExteriorControl x:Name="exteriorManager"/>
            </TabItem>

            <!-- Interior Features -->
            <TabItem Header="🏠 Interior">
                <local:InteriorControl x:Name="interiorManager"/>
            </TabItem>

            <!-- ═══ Tab 6: Materials ═══ -->
            <TabItem Header="📋 Materials">
                <local:MaterialsControl x:Name="materialsControl"/>
            </TabItem>

            <!-- ═══ Tab 7: Output ═══ -->
            <TabItem Header="🧠 Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <GroupBox Header="Stories / Floors">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Number of Floors:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtNumFloors" Text="1" Width="70"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Floor Heights (ft, CSV):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtFloorHeights" Text="" Width="180"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Floor Connection:"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbFloorConnection" Width="180" SelectedIndex="0">
                                    <ComboBoxItem Content="Continuous Posts"/>
                                    <ComboBoxItem Content="Spliced Posts"/>
                                </ComboBox>

                                <Label Grid.Row="3" Grid.Column="0" Content="Floor Beam Size:"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtFloorBeamSize" Text="2-2x12 LVL" Width="140"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Curved Building">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="chkCurvedWalls"
                                          Content="Enable Curved Walls" Margin="2,4"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Radius (ft):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtCurveRadius" Text="120" Width="80"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Arc Angle (deg):"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtCurveAngle" Text="45" Width="80"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="Mode:"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbCurveMode" Width="170" SelectedIndex="0">
                                    <ComboBoxItem Content="Arc Length Driven"/>
                                    <ComboBoxItem Content="Chord Driven"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Complex Footprint">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Footprint Shape:"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbFootprintShape" Width="170" SelectedIndex="0">
                                    <ComboBoxItem Content="Rectangle"/>
                                    <ComboBoxItem Content="L-Shape"/>
                                    <ComboBoxItem Content="T-Shape"/>
                                    <ComboBoxItem Content="U-Shape"/>
                                    <ComboBoxItem Content="Custom Polygon"/>
                                </ComboBox>

                                <Label Grid.Row="1" Grid.Column="0" Content="Inset Width (ft):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtFootprintInsetWidth" Text="10" Width="80"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Inset Depth (ft):"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtFootprintInsetDepth" Text="10" Width="80"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="Custom Vertices (x:y CSV):"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtFootprintVertices" Text="" Width="210"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Expansion Joints">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="3" x:Name="chkExpansionJoints"
                                          Content="Enable Expansion Joints" Margin="2,4"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Joint Locations (ft, CSV):"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtJointLocations" Text="" Width="180"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Suggest" Width="80" Click="OnSuggestJoints"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Gap Width (ft):"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtJointGap" Text="0.5" Width="80"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="Joint Type:"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbJointType" Width="170" SelectedIndex="0">
                                    <ComboBoxItem Content="Slip Plate"/>
                                    <ComboBoxItem Content="Double Post"/>
                                    <ComboBoxItem Content="Isolation Gap"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Dairy Barn">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="chkDairyEnabled"
                                          Content="Enable Dairy Barn Module" Margin="2,4"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Parlor Type:"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbParlorType" Width="170" SelectedIndex="0">
                                    <ComboBoxItem Content="Herringbone"/>
                                    <ComboBoxItem Content="Parallel"/>
                                    <ComboBoxItem Content="Rotary"/>
                                </ComboBox>

                                <Label Grid.Row="2" Grid.Column="0" Content="Herd Size:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtHerdSize" Text="120" Width="80"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Equipment Storage">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="chkEquipStorageEnabled"
                                          Content="Enable Equipment Storage Mode" Margin="2,4"/>
                                <CheckBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="chkClearSpan"
                                          Content="Require Clear-Span (No Interior Posts)" Margin="2,4" IsChecked="True"/>

                                <CheckBox Grid.Row="2" Grid.ColumnSpan="2" x:Name="chkCraneRail"
                                          Content="Enable Crane Rails" Margin="2,4"/>
                                <Label Grid.Row="3" Grid.Column="0" Content="Rail Height / Capacity:"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="txtCraneRailHeight" Text="16" Width="50"/>
                                    <Label Content="ft /"/>
                                    <TextBox x:Name="txtCraneCapacity" Text="5" Width="50"/>
                                    <Label Content="tons"/>
                                </StackPanel>

                                <CheckBox Grid.Row="4" Grid.ColumnSpan="2" x:Name="chkLargeDoor"
                                          Content="Enable Large Door System" Margin="2,4"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="cmbLargeDoorType" Width="90" SelectedIndex="0">
                                        <ComboBoxItem Content="Bifold"/>
                                        <ComboBoxItem Content="Hydraulic"/>
                                    </ComboBox>
                                    <TextBox x:Name="txtLargeDoorWidth" Text="30" Width="50"/>
                                    <Label Content="x"/>
                                    <TextBox x:Name="txtLargeDoorHeight" Text="16" Width="50"/>
                                    <Label Content="ft"/>
                                </StackPanel>
                                <Label Grid.Row="5" Grid.Column="0" Content="Door Type / Size:"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Agricultural">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="chkGrainStorage"
                                          Content="Enable Grain Storage Layout" Margin="2,4"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="txtBinPadCount" Text="2" Width="50"/>
                                    <Label Content="pads @"/>
                                    <TextBox x:Name="txtBinPadDiameter" Text="24" Width="50"/>
                                    <Label Content="ft dia"/>
                                </StackPanel>
                                <Label Grid.Row="1" Grid.Column="0" Content="Bin Pad Layout:"/>

                                <CheckBox Grid.Row="2" Grid.ColumnSpan="2" x:Name="chkMachineryBuilding"
                                          Content="Enable Machinery Building Mode" Margin="2,4"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="txtMachineryBayWidth" Text="40" Width="50"/>
                                    <Label Content="ft clear-span, eave"/>
                                    <TextBox x:Name="txtMachineryEaveHeight" Text="20" Width="50"/>
                                    <Label Content="ft"/>
                                </StackPanel>
                                <Label Grid.Row="3" Grid.Column="0" Content="Machinery Bays:"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 8: Output ═══ -->
            <TabItem Header="📄 Output">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <GroupBox Header="Output Views">
                            <WrapPanel>
                                <CheckBox x:Name="chkPlan" Content="Plan View" IsChecked="True" Margin="8,4"/>
                                <CheckBox x:Name="chkFront" Content="Front Elevation" IsChecked="True" Margin="8,4"/>
                                <CheckBox x:Name="chkSide" Content="Side Elevation" IsChecked="True" Margin="8,4"/>
                                <CheckBox x:Name="chk3D" Content="3D Wireframe" IsChecked="True" Margin="8,4"/>
                                <CheckBox x:Name="chkDims" Content="Auto-Dimension" IsChecked="True" Margin="8,4"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
