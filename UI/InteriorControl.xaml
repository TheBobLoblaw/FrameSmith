<UserControl x:Class="PoleBarnGenerator.UI.InteriorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    
    <TabControl>
        <!-- Horse Barn Tab -->
        <TabItem Header="🐴 Horse Barn">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <GroupBox Header="Stall Configuration" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="chkStallsEnabled" Content="Enable Horse Barn Layout"
                                      IsChecked="{Binding HorseStalls.IsEnabled}" Margin="0,4"/>
                            
                            <StackPanel Visibility="{Binding IsChecked, ElementName=chkStallsEnabled, Converter={StaticResource BoolToVisibility}}"
                                        Margin="12,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="Number of Stalls:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <Slider x:Name="sldStallCount" Grid.Row="0" Grid.Column="1" 
                                            Value="{Binding HorseStalls.NumberOfStalls}" 
                                            Minimum="2" Maximum="20" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1"
                                            Margin="8,4"/>
                                    <TextBlock Text="{Binding Value, ElementName=sldStallCount, StringFormat={}{0:F0}}" 
                                               Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                                    
                                    <TextBlock Text="Standard Size:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4"
                                              SelectedIndex="1">
                                        <ComboBoxItem Content="10' × 10'" Tag="Size10x10"/>
                                        <ComboBoxItem Content="10' × 12'" Tag="Size10x12"/>
                                        <ComboBoxItem Content="12' × 12'" Tag="Size12x12"/>
                                        <ComboBoxItem Content="12' × 14'" Tag="Size12x14"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Aisle Width:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <Slider x:Name="sldAisle" Grid.Row="2" Grid.Column="1"
                                            Value="{Binding HorseStalls.AisleWidth}"
                                            Minimum="10" Maximum="16" SmallChange="0.5"
                                            Margin="8,4"/>
                                    <TextBlock Text="{Binding Value, ElementName=sldAisle, StringFormat={}{0:F1} ft}"
                                               Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"/>
                                    
                                    <TextBlock Text="Stall Layout:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4"
                                              SelectedIndex="2">
                                        <ComboBoxItem Content="Left Side Only" Tag="Left"/>
                                        <ComboBoxItem Content="Right Side Only" Tag="Right"/>
                                        <ComboBoxItem Content="Both Sides" Tag="Both"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="Specialty Rooms" Margin="0,0,0,8"
                              Visibility="{Binding IsChecked, ElementName=chkStallsEnabled, Converter={StaticResource BoolToVisibility}}">
                        <UniformGrid Columns="3" Margin="4">
                            <CheckBox Content="Tack Room" IsChecked="{Binding HorseStalls.TackRoom.IsEnabled}" Margin="4"/>
                            <CheckBox Content="Feed Room" IsChecked="{Binding HorseStalls.FeedRoom.IsEnabled}" Margin="4"/>
                            <CheckBox Content="Wash Bay" IsChecked="{Binding HorseStalls.WashBay.IsEnabled}" Margin="4"/>
                        </UniformGrid>
                    </GroupBox>

                    <GroupBox Header="Horse Facility Upgrades" Margin="0,0,0,8"
                              Visibility="{Binding IsChecked, ElementName=chkStallsEnabled, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="4">
                            <TextBlock Text="Ventilation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <WrapPanel>
                                <CheckBox x:Name="chkVentEnabled" Content="Enable Ventilation" Margin="4"/>
                                <CheckBox x:Name="chkRidgeVent" Content="Ridge Vent" Margin="4"/>
                                <CheckBox x:Name="chkCupolas" Content="Cupolas" Margin="4"/>
                                <CheckBox x:Name="chkWallLouvers" Content="Wall Louvers" Margin="4"/>
                            </WrapPanel>

                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cupola Count:" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCupolaCount" Grid.Column="1" Text="1" Width="50"/>
                                <TextBlock Grid.Column="2" Text="Louver Count:" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtLouverCount" Grid.Column="3" Text="4" Width="50"/>
                            </Grid>

                            <TextBlock Text="Drainage" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <WrapPanel>
                                <CheckBox x:Name="chkDrainEnabled" Content="Enable Drainage Plan" Margin="4"/>
                                <CheckBox x:Name="chkFrenchDrain" Content="French Drain" Margin="4"/>
                            </WrapPanel>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Floor Slope (%):" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtFloorSlope" Grid.Column="1" Text="1.5" Width="60"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <!-- Loft/Storage Tab -->
        <TabItem Header="📦 Loft/Storage">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <GroupBox Header="Loft Configuration" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="chkLoftEnabled" Content="Enable Storage Loft" 
                                      IsChecked="{Binding Loft.IsEnabled}" Margin="0,4"/>
                            
                            <StackPanel Visibility="{Binding IsChecked, ElementName=chkLoftEnabled, Converter={StaticResource BoolToVisibility}}"
                                        Margin="12,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="Floor Height:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <Slider x:Name="sldFloorHeight" Grid.Row="0" Grid.Column="1"
                                            Value="{Binding Loft.FloorHeight}"
                                            Minimum="7" Maximum="12" SmallChange="0.5"
                                            Margin="8,4"/>
                                    <TextBlock Text="{Binding Value, ElementName=sldFloorHeight, StringFormat={}{0:F1} ft}" 
                                               Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                                    
                                    <TextBlock Text="Access Type:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Stairs" Tag="Stairs"/>
                                        <ComboBoxItem Content="Straight Ladder" Tag="StraightLadder"/>
                                        <ComboBoxItem Content="Ship Ladder" Tag="ShipLadder"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Joist Spacing:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,4"
                                              SelectedIndex="1">
                                        <ComboBoxItem Content='12" OC' Tag="12"/>
                                        <ComboBoxItem Content='16" OC' Tag="16"/>
                                        <ComboBoxItem Content='24" OC' Tag="24"/>
                                    </ComboBox>
                                </Grid>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="Show Floor Joists" IsChecked="{Binding Loft.HasFloorJoists}" Margin="0,0,16,0"/>
                                    <CheckBox Content="Electrical Outlets" IsChecked="{Binding Loft.HasLighting}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <!-- Partitions & Workshop Tab -->
        <TabItem Header="🔧 Partitions">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <GroupBox Header="Interior Partitions" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="chkPartitionsEnabled" Content="Enable Interior Partitions" 
                                      IsChecked="{Binding Partitions.IsEnabled}" Margin="0,4"/>
                            
                            <StackPanel Visibility="{Binding IsChecked, ElementName=chkPartitionsEnabled, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,8,0,0">
                                <DataGrid x:Name="dgPartitions" 
                                          ItemsSource="{Binding Partitions.Partitions}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          Height="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100"/>
                                        <DataGridComboBoxColumn Header="Type" Width="100">
                                            <DataGridComboBoxColumn.ItemsSource>
                                                <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>Frame Wall</sys:String>
                                                    <sys:String>Chain Link</sys:String>
                                                    <sys:String>Pipe Panel</sys:String>
                                                    <sys:String>Board Fence</sys:String>
                                                    <sys:String>Concrete Block</sys:String>
                                                </x:Array>
                                            </DataGridComboBoxColumn.ItemsSource>
                                        </DataGridComboBoxColumn>
                                        <DataGridTextColumn Header="Height" Binding="{Binding Height}" Width="60"/>
                                        <DataGridCheckBoxColumn Header="Door" Binding="{Binding HasDoor}" Width="50"/>
                                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="Workshop Features" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="chkWorkshopEnabled" Content="Enable Workshop Layout" 
                                      IsChecked="{Binding Workshop.IsEnabled}" Margin="0,4"/>
                            
                            <UniformGrid Columns="2" Margin="12,4,0,0"
                                         Visibility="{Binding IsChecked, ElementName=chkWorkshopEnabled, Converter={StaticResource BoolToVisibility}}">
                                <CheckBox Content="Workbench" IsChecked="{Binding Workshop.HasWorkbench}" Margin="4"/>
                                <CheckBox Content="Compressor Area" IsChecked="{Binding Workshop.HasCompressorArea}" Margin="4"/>
                                <CheckBox Content="Tool Storage" IsChecked="{Binding Workshop.HasToolStorage}" Margin="4"/>
                                <CheckBox Content="Floor Drain" IsChecked="{Binding Workshop.HasFloorDrain}" Margin="4"/>
                                <CheckBox Content="Overhead Crane" IsChecked="{Binding Workshop.HasOverheadCrane}" Margin="4"/>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
